# Spark Atlas desktop build-time profile.
# This file is read by scripts/generate-profile.mjs before every dev/build run.
# Values here are baked into src/shared/profile.ts and electron-builder.generated.yml.

# Optional alternate JSON fallback profile. Environment variables below override it.
DESKTOP_PROFILE=profiles/default.json

# --- Brand ---
# User-facing application brand. Default brand name is Spark Atlas.
DESKTOP_BRAND_NAME=Spark Atlas
DESKTOP_BRAND_DESKTOP_NAME=Spark Atlas
DESKTOP_SERVICE_NAME=Spark Atlas
DESKTOP_DESCRIPTION=Spark Atlas
DESKTOP_AUTHOR=Spark Atlas
DESKTOP_HOMEPAGE=https://chat.spark-ai.top
DESKTOP_OFFICIAL_WEBSITE_URL=https://spark-ai.top
DESKTOP_COPYRIGHT_TEXT=Copyright (c) 2026 AntiStormStudio. All rights reserved.
DESKTOP_CREATOR_TEXT=Created by AntiStormStudio
# Package/artifact base name used by packaged metadata and installer file names.
DESKTOP_PACKAGE_NAME=spark-atlas-desktop
DESKTOP_APP_ID=com.sparkatlas.desktop
DESKTOP_EXECUTABLE_NAME=spark-atlas
DESKTOP_LINUX_MAINTAINER=spark-ai.top
DESKTOP_GITHUB_OWNER=AntiStormStudio
DESKTOP_GITHUB_REPO=desktop

# --- Feature switches ---
# true/false. These are compile-time flags and are enforced in both UI and IPC.
DESKTOP_ALLOW_LOCAL_OPENWEBUI_INSTALL=false
DESKTOP_ALLOW_USER_REMOTE_OPENWEBUI=false
DESKTOP_DEFAULT_REMOTE_OPENWEBUI=https://chat.spark-ai.top
DESKTOP_DEFAULT_REMOTE_OPENWEBUI_NAME=Spark Atlas
# remote or local. local only takes effect when DESKTOP_ALLOW_LOCAL_OPENWEBUI_INSTALL=true.
DESKTOP_DEFAULT_LANDING_MODE=remote
DESKTOP_ALLOW_REMOTE_PASSKEYS=true
DESKTOP_ALLOW_REMOTE_DESKTOP_BRIDGE=true
DESKTOP_ALLOW_REMOTE_NATIVE_API=true
DESKTOP_ALLOW_REMOTE_LOCAL_RESOURCES=true

# --- Remote permissions ---
# Comma-separated Electron permission names allowed for remote webviews.
DESKTOP_REMOTE_PERMISSIONS_ALLOWED=media,mediaKeySystem,notifications,clipboard-read,clipboard-sanitized-write,clipboard-read-write,fullscreen,geolocation,hid,serial,usb,pointerLock

# --- Auth and passkey navigation ---
# When true, origins listed below may stay inside the webview during auth/passkey flows.
DESKTOP_AUTH_ALLOW_EXTERNAL_ORIGINS_IN_WEBVIEW=true
# Comma-separated origins, for example: https://login.example.com,https://auth.example.com
DESKTOP_AUTH_ALLOWED_ORIGINS=

# --- Desktop bridge ---
# Comma-separated capability allowlist exposed to remote instances through window.openWebUIDesktop.
DESKTOP_DESKTOP_BRIDGE_ALLOWED_CAPABILITIES=app.info,app.openExternal,app.openSettings,system.platform,system.selectFolder,resources.openPath,resources.selectFile,terminal.local.info,terminal.local.ensure,terminal.local.stop

# --- Updates ---
# DESKTOP_UPDATE_PROVIDER supports github or generic.
# For github, set owner/repo. For generic, set DESKTOP_UPDATE_URL.
DESKTOP_UPDATE_PROVIDER=generic
DESKTOP_UPDATE_OWNER=open-webui
DESKTOP_UPDATE_REPO=desktop
DESKTOP_UPDATE_URL=https://chat.spark-ai.top/api/v1/configs/apps/updates/desktop/
DESKTOP_UPDATE_CACHE_DIR=spark-atlas-updater

# --- Logo and app assets ---
# The build step copies these files into resources/, build/, and renderer splash assets.
DESKTOP_ICON_DIR=/Users/cary/Desktop/Fun/Spark Atlas/icons
DESKTOP_ICON_PNG=light.png
DESKTOP_ICON_ICO=light.ico
DESKTOP_TRAY_PNG=carved_light.png
# macOS Dock icons look visually larger than other apps when artwork fills the full canvas.
# Scale the source artwork inside a transparent 1024px canvas before generating .icns.
DESKTOP_MAC_ICON_SCALE=0.82
DESKTOP_SPLASH_LIGHT_PNG=carved_light.png
DESKTOP_SPLASH_DARK_PNG=carved_dark.png
